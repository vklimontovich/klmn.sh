# GitHub token for GHCR registry authentication
# Get it: https://github.com/settings/tokens -> Generate new token (classic) -> select read:packages
export can=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tailscale auth key to join nodes to your tailnet
# Get it: https://login.tailscale.com/admin/settings/keys -> Generate auth key
# Tip: enable "Reusable" for multiple nodes, set expiry as needed
export TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxxxxxxxxxx

# Cloudflare API token for DNS management (internet-gateway operator)
# Get it: https://dash.cloudflare.com/profile/api-tokens -> Create Token
# Permissions needed: Zone:Read, DNS:Edit
export CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Let's Encrypt email for SSL certificates (cert-manager)
export LETSENCRYPT_EMAIL=your-email@example.com

# GCP service account key JSON (optional, enables PostgreSQL backups to GCS)
# Create SA: gcloud iam service-accounts create postgres-backup
# Create key: gcloud iam service-accounts keys create key.json --iam-account=postgres-backup@PROJECT.iam.gserviceaccount.com
# export GCP_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"..."}'

# GCS bucket name for PostgreSQL backups
# export GCS_BACKUP_BUCKET=backups.pg.klmn.sh

# MTProxy stats endpoint auth token (X-Admin-Token header), comma-separated for multiple
export ADMIN_INTERFACE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# enter.greatinet.org VLESS+REALITY exit (xray-client outbound)
# Point enter at one of the k8s xray exit nodes (a node-role=vpn-node host).
# UUID/public-key/short-id must match the xray REALITY server config (k8s/030-xray);
# SNI must be one of that server's serverNames.
export ENTER_EXIT_HOST=salmon.greatinet.org
export ENTER_VLESS_SNI=investing.com
export ENTER_VLESS_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
export ENTER_VLESS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export ENTER_VLESS_SHORT_ID=xxxxxxxxxx
